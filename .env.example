# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only (pipeline)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key       # browser auth client

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── News Sources ──────────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key
FINNHUB_API_KEY=your-finnhub-key

# ── Mapbox ────────────────────────────────────────────────────────────────────
# Server-side: geocoding in the pipeline
MAPBOX_PUBLIC_TOKEN=pk.eyJ1...
# Client-side: map rendering in the browser (same token, NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
NEXT_PUBLIC_APP_URL=https://your-app-url.vercel.app
TEST_EMAIL_OVERRIDE=you@example.com   # dev only — remove when real domain is set up

# ── Pipeline ──────────────────────────────────────────────────────────────────
PIPELINE_SECRET=your-random-secret   # for manual triggers
CRON_SECRET=                         # auto-set by Vercel in production; leave blank locally

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com   # email of the admin user — gates /admin and receives pipeline failure alerts
