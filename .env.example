# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key       # browser auth client

# ── AI ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile   # optional — this is the default

# ── News Sources ──────────────────────────────────────────────────────────────
NEWSAPI_KEY=your-newsapi-key
FINNHUB_API_KEY=your-finnhub-key

# ── Mapbox ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ── Email ─────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app   # must be your production URL — used in email links
# TEST_EMAIL_OVERRIDE=you@example.com             # dev only — DO NOT add this in Vercel

# ── Pipeline & Cron ───────────────────────────────────────────────────────────
PIPELINE_SECRET=your-random-secret   # guards /api/pipeline/run manual triggers
CRON_SECRET=your-random-secret       # Vercel Cron sends this; also signs unsubscribe tokens

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com   # gates /admin and receives pipeline failure alert emails

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...             # server-side error capture
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/... # client-side (same DSN, public prefix required)
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
